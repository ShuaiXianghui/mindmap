{
  "meta": {
    "name": "三大杠杆：AI+编程、互联网内容、知识复利",
    "source": "对话整理"
  },
  "nodes": [
    {
      "id": "root",
      "name": "三大杠杆体系",
      "children": [
        {
          "id": "l1",
          "name": "一、AI + 编程：当前最强大的杠杆",
          "children": [
            {
              "id": "l1-why",
              "name": "为什么是第一？",
              "children": [
                {"id": "l1-why-1", "name": "编程本身是顶级杠杆：写一次代码，跑无限次"},
                {"id": "l1-why-2", "name": "AI 是“杠杆的杠杆”：让编程本身被杠杆化"},
                {"id": "l1-why-3", "name": "无 AI：几周上线 → 有 AI：几小时上线"}
              ]
            },
            {
              "id": "l1-levels",
              "name": "具体的使用层次与杠杆倍数",
              "children": [
                {"id": "l1-level-1", "name": "用 ChatGPT 问问题 | 2-5x"},
                {"id": "l1-level-2", "name": "用 Claude/Copilot 写代码 | 5-20x"},
                {"id": "l1-level-3", "name": "让 AI 做完整模块 | 20-50x"},
                {"id": "l1-level-4", "name": "AI Agent 自主完成 | 50-200x"},
                {"id": "l1-level-5", "name": "AI + 自动化流水线 | 200x+"}
              ]
            },
            {
              "id": "l1-core",
              "name": "AI 杠杆的核心能力",
              "children": [
                {"id": "l1-core-1", "name": "知识获取速度：30分钟 → 30秒（60x）"},
                {"id": "l1-core-2", "name": "执行速度：2天 → 2小时（8x）"},
                {"id": "l1-core-3", "name": "领域跨越：后端工程师 + AI = 全栈"},
                {"id": "l1-core-4", "name": "试错成本趋零：让 AI 试 5 个方案"}
              ]
            },
            {
              "id": "l1-tips",
              "name": "怎么把 AI 杠杆用到极致",
              "children": [
                {"id": "l1-tips-1", "name": "心法一：让 AI 做你不擅长的，你专注做判断。从打字的人变成决策的人"},
                {"id": "l1-tips-2", "name": "心法二：建立你自己的 AI 工作流（CLAUDE.md / 技能记忆 / 自动化）"},
                {"id": "l1-tips-3", "name": "心法三：用 AI 学 AI —— 复利的复利"}
              ]
            }
          ]
        },
        {
          "id": "l2",
          "name": "二、互联网内容：睡后杠杆",
          "children": [
            {
              "id": "l2-why",
              "name": "为什么是睡后杠杆",
              "children": [
                {"id": "l2-why-1", "name": "睡觉时：文章被读、视频被推荐、项目被发现"},
                {"id": "l2-why-2", "name": "一次创作，永久分发，边际成本为零"}
              ]
            },
            {
              "id": "l2-levels",
              "name": "内容杠杆的层次",
              "children": [
                {"id": "l2-level-1", "name": "一次性内容（推文/帖子） | 24小时有效"},
                {"id": "l2-level-2", "name": "半持久内容（博客/教程） | 长尾流量数年"},
                {"id": "l2-level-3", "name": "持久资产（开源项目/工具） | 网络效应"},
                {"id": "l2-level-4", "name": "复合资产（书/课程/品牌） | 积累质变"}
              ]
            },
            {
              "id": "l2-formula",
              "name": "关键公式",
              "children": [
                {"id": "l2-formula-1", "name": "内容杠杆价值 = 触达人数 × 人均影响深度 × 持续时间"},
                {"id": "l2-formula-2", "name": "爆款推文：100万人×浅层×1天 → 价值有限"},
                {"id": "l2-formula-3", "name": "深度教程：1万人×深度×3年 → 价值巨大"}
              ]
            },
            {
              "id": "l2-special",
              "name": "互联网杠杆的特殊之处",
              "children": [
                {"id": "l2-special-1", "name": "Permissionless（无需许可）"},
                {"id": "l2-special-2", "name": "全球分发"},
                {"id": "l2-special-3", "name": "可组合：文章 → 视频 → 课程 → 书"},
                {"id": "l2-special-4", "name": "发现机制：搜索与推荐"}
              ]
            },
            {
              "id": "l2-how",
              "name": "具体怎么做",
              "children": [
                {"id": "l2-how-1", "name": "最小化开始：写你正在学的东西，比读者早一步"},
                {"id": "l2-how-2", "name": "编程 + 内容结合（杠杆叠加）：写代码 → 写博客 → 开源 → 获客"},
                {
                  "id": "l2-how-3",
                  "name": "平台选择策略",
                  "children": [
                    {"id": "l2-how-3-cn", "name": "中文圈：公众号/即刻/少数派/B站"},
                    {"id": "l2-how-3-en", "name": "英文圈：Twitter/个人博客/GitHub/YouTube"},
                    {"id": "l2-how-3-core", "name": "核心：拥有自己的分发渠道（博客、邮件列表）"}
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "l3",
          "name": "三、知识复利：所有杠杆的元杠杆",
          "children": [
            {
              "id": "l3-what",
              "name": "什么是知识复利",
              "children": [
                {"id": "l3-what-1", "name": "知识越用越多（钱/时间越用越少）"},
                {"id": "l3-what-2", "name": "10本书：孤立点 → 100本书：网络 → 500本书：看见模式"},
                {"id": "l3-what-3", "name": "查理·芒格：思维模型网格"}
              ]
            },
            {
              "id": "l3-mech",
              "name": "知识复利的核心机制",
              "children": [
                {"id": "l3-mech-1", "name": "知识产生知识：编程→写工具→加速学习→正循环"},
                {"id": "l3-mech-2", "name": "模式识别加速：见过100个，第101个3秒判断"},
                {"id": "l3-mech-3", "name": "决策质量提升：多模型交叉验证"},
                {"id": "l3-mech-4", "name": "信任溢价：积累带来影响力"}
              ]
            },
            {
              "id": "l3-priority",
              "name": "最值得投资的元知识（优先级）",
              "children": [
                {"id": "l3-priority-s1", "name": "S级：学习方法本身 — 加速一切后续学习"},
                {"id": "l3-priority-s2", "name": "S级：思维模型（各学科核心思想）— 更好决策"},
                {"id": "l3-priority-a1", "name": "A级：编程 / AI — 时代最高杠杆工具"},
                {"id": "l3-priority-a2", "name": "A级：写作 / 表达 — 放大所有能力"},
                {"id": "l3-priority-a3", "name": "A级：英语 — 打开全球信息源"},
                {"id": "l3-priority-b1", "name": "B级：财务 / 投资 — 保护和管理财富"},
                {"id": "l3-priority-b2", "name": "B级：心理学 / 人性 — 理解自己和他人"}
              ]
            },
            {
              "id": "l3-system",
              "name": "怎么建立知识复利系统",
              "children": [
                {
                  "id": "l3-system-in",
                  "name": "输入",
                  "children": [
                    {"id": "l3-system-in-1", "name": "书（最系统，密度最高）"},
                    {"id": "l3-system-in-2", "name": "长文 / 深度博客"},
                    {"id": "l3-system-in-3", "name": "和人聊"}
                  ]
                },
                {
                  "id": "l3-system-proc",
                  "name": "处理",
                  "children": [
                    {"id": "l3-system-proc-1", "name": "做笔记：写自己的理解"},
                    {"id": "l3-system-proc-2", "name": "连接旧知识"},
                    {"id": "l3-system-proc-3", "name": "输出：写 / 讲 / 做"}
                  ]
                },
                {
                  "id": "l3-system-loop",
                  "name": "读 / 想 / 写 / 做 循环",
                  "children": [
                    {"id": "l3-system-loop-1", "name": "大量阅读（每天1-2小时）"},
                    {"id": "l3-system-loop-2", "name": "思考连接（散步时、独处时）"},
                    {"id": "l3-system-loop-3", "name": "写下来（每周一篇）"},
                    {"id": "l3-system-loop-4", "name": "用起来（知识→代码/产品/决策）"}
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "l4",
          "name": "三者如何叠加（飞轮效应）",
          "children": [
            {"id": "l4-formula", "name": "杠杆总倍数 = AI×编程 × 互联网内容 × 知识复利"},
            {
              "id": "l4-example",
              "name": "具体飞轮示例",
              "children": [
                {"id": "l4-ex-1", "name": "用 AI 快速学新技术（知识复利 × AI）"},
                {"id": "l4-ex-2", "name": "用 AI + 编程做工具（AI × 编程）"},
                {"id": "l4-ex-3", "name": "写博客讲工具（互联网内容）"},
                {"id": "l4-ex-4", "name": "博客带来咨询（内容 → 机会）"},
                {"id": "l4-ex-5", "name": "咨询学到新东西（机会 → 知识）"},
                {"id": "l4-ex-6", "name": "新知识做更好产品（知识 → 产品）"}
              ]
            },
            {"id": "l4-flywheel", "name": "一旦转起来，每一圈都比上一圈快"}
          ]
        },
        {
          "id": "l5",
          "name": "你现在的位置与下一步",
          "children": [
            {"id": "l5-now", "name": "已经在用 Claude Code（AI×编程）"},
            {"id": "l5-next", "name": "正探索和整理知识（知识复利的处理阶段）"},
            {"id": "l5-action", "name": "下一步：把这次讨论写成文章/分享出去（互联网内容）"},
            {"id": "l5-sum", "name": "一次行动，三个杠杆全用上"}
          ]
        }
      ]
    }
  ]
}